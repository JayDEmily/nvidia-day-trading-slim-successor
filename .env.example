# Lightweight local default for rapid sandbox/dev iteration.
NVDA_DESK_DATABASE_URL=sqlite+pysqlite:///./var/nvda_desk_dev.db

# Intended Docker/Postgres path once promoting beyond the lightweight SQLite backbone:
# NVDA_DESK_DATABASE_URL=postgresql+psycopg://nvda:nvda@127.0.0.1:54329/nvda_desk

NVDA_DESK_MARKET_TIMEZONE=America/New_York
NVDA_DESK_PRE_MARKET_START_HOUR=4
NVDA_DESK_REGULAR_OPEN_HOUR=9
NVDA_DESK_REGULAR_OPEN_MINUTE=30
NVDA_DESK_REGULAR_CLOSE_HOUR=16
NVDA_DESK_REGULAR_CLOSE_MINUTE=0
NVDA_DESK_AFTER_HOURS_END_HOUR=20
