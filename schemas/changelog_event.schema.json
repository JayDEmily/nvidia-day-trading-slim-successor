{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nvda-desk.local/schemas/changelog_event.schema.json",
  "title": "ChangelogEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "change_id",
    "ts_unix_ms",
    "ts_utc",
    "author",
    "scope",
    "kind",
    "summary",
    "problem",
    "change",
    "why",
    "files_changed",
    "breaking_change",
    "migration_required",
    "tests_run",
    "rollback",
    "status"
  ],
  "properties": {
    "change_id": {
      "type": "string",
      "minLength": 1
    },
    "ts_unix_ms": {
      "type": "integer",
      "minimum": 0
    },
    "ts_utc": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "docs",
        "scaffold",
        "contracts",
        "database",
        "services",
        "api",
        "runtime",
        "tests",
        "ops"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "change": {
      "type": "string",
      "minLength": 1
    },
    "why": {
      "type": "string",
      "minLength": 1
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "breaking_change": {
      "type": "boolean"
    },
    "migration_required": {
      "type": "boolean"
    },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "applied",
        "superseded",
        "reverted",
        "draft"
      ]
    }
  }
}
