  "global_rules": {
    "one_leaf_at_a_time": true,
    "one_gate_at_a_time": true,
    "branch_per_gate": true,
    "planning_control_surfaces_must_move_together": true,
    "vocabulary_authority_mandatory_before_new_naming": true,
    "packet_contract_authority_mandatory_when_contracts_change": true,
    "workflow_trace_mandatory_before_planning_new_behavior": true,
    "retire_from_authority_not_delete": true,
    "git_history_primary_execution_ledger": true,
    "zip_required_only_on_explicit_operator_request_or_backup": true,
    "do_not_fill_unknowns_with_guesswork": true,
    "document_touch_checklist_required": true,
    "completed_and_remaining_leaf_sets_must_be_disjoint": true,
    "multi_gate_requests_do_not_waive_per_gate_closeout": true,
    "controlled_continuity_requires_explicit_pack_authorisation": true,
    "merge_before_next_gate_when_continuity_authorised": true,
    "continuous_run_stops_on_any_failed_proof_or_declared_stop_condition": true,
    "planner_must_define_closed_world_scope": true,
    "planner_must_define_allowed_fallout_repair_scope": true,
    "material_control_surface_contradictions_require_contradiction_report": true,
    "latest_closed_pack_is_evidence_not_template": true,
    "gate_and_leaf_counts_are_variable_but_must_preserve_granularity": true,
    "tests_must_prefer_invariants_over_brittle_historical_strings": true
