  "families": {
    "trend_continuation": {
      "title": "Trend Continuation",
      "thesis": "Persistent directional tape with supportive breadth and non-hostile options context."
    },
    "compression_release": {
      "title": "Compression Release",
      "thesis": "Compressed tape or options surface releases into directional range expansion."
    },
    "pin_behaviour": {
      "title": "Pin Behaviour",
      "thesis": "Strike-magnet behaviour dominates and favours mean reversion or controlled trim. "
    },
    "gamma_destabilisation": {
      "title": "Gamma Destabilisation",
      "thesis": "Dealer pressure amplifies price movement and supports flush-style or hedge-led responses."
    },
    "term_structure_dislocation": {
      "title": "Term Structure Dislocation",
      "thesis": "Front-versus-next expiry dislocation distorts the curve and creates a normalisation setup."
    },
    "skew_pressure_transition": {
      "title": "Skew Pressure Transition",
      "thesis": "Skew pressure relaxes or reverses without a full destabilised flush."
    }
  },
  "execution_templates": {
    "continuation_ladder_exec": {
      "entry_style": "trend_ladder_3_step",
      "scaling_step_factors": [
        0.2,
        0.3,
        0.5
      ],
      "default_inventory_action": "add",
      "default_fresh_capital_action": "add",
      "thesis_invalidation_state": "trend_structure_broken",
      "exit_reasons": [
        "trim_into_extension",
        "exit_on_breadth_reversal"
      ]
    },
    "compression_breakout_exec": {
