{
  "ordered_playbooks": [
    "continuation_ladder",
    "compression_breakout",
    "pin_reversion",
    "negative_gamma_flush",
    "front_expiry_pin_pressure",
    "term_structure_dislocation",
    "skew_pressure_reversal"
  ],
  "playbook_profiles": {
    "continuation_ladder": {
      "eligible_action_bias": "add",
      "eligible_sizing_fraction": 0.35,
      "watch_action_bias": "hold",
      "watch_hedge_overlay": false,
      "template_id": "continuation_ladder_exec"
    },
    "compression_breakout": {
      "eligible_action_bias": "add",
      "eligible_sizing_fraction": 0.25,
      "watch_action_bias": "hold",
      "watch_hedge_overlay": false,
      "template_id": "compression_breakout_exec"
    },
    "pin_reversion": {
      "eligible_action_bias": "trim",
      "eligible_sizing_fraction": 0.2,
      "watch_action_bias": "hold",
      "watch_hedge_overlay": false,
      "template_id": "pin_reversion_exec"
    },
    "negative_gamma_flush": {
      "eligible_action_bias": "add",
      "eligible_sizing_fraction": 0.1,
      "watch_action_bias": "hedge",
      "watch_hedge_overlay": true,
      "template_id": "negative_gamma_flush_exec"
    },
    "front_expiry_pin_pressure": {
      "eligible_action_bias": "trim",
      "eligible_sizing_fraction": 0.15,
      "watch_action_bias": "hold",
      "watch_hedge_overlay": false,
      "template_id": "front_expiry_pin_pressure_exec"
    },
    "term_structure_dislocation": {
      "eligible_action_bias": "add",
      "eligible_sizing_fraction": 0.12,
      "watch_action_bias": "hold",
      "watch_hedge_overlay": false,
      "template_id": "term_structure_dislocation_exec"
    },
    "skew_pressure_reversal": {
      "eligible_action_bias": "hedge",
      "eligible_sizing_fraction": 0.1,
      "watch_action_bias": "hedge",
      "watch_hedge_overlay": true,
      "template_id": "skew_pressure_reversal_exec"
    }
  },
  "execution_templates": {
    "continuation_ladder_exec": {
      "entry_style": "trend_ladder_3_step",
      "scaling_step_factors": [
        0.2,
        0.3,
        0.5
      ],
      "default_inventory_action": "add",
      "default_fresh_capital_action": "add",
      "thesis_invalidation_state": "trend_structure_broken",
      "exit_reasons": [
        "trim_into_extension",
        "exit_on_breadth_reversal"
      ]
    },
    "compression_breakout_exec": {
      "entry_style": "compression_release_ladder",
      "scaling_step_factors": [
        0.3,
        0.3,
        0.4
      ],
      "default_inventory_action": "add",
      "default_fresh_capital_action": "add",
      "thesis_invalidation_state": "compression_failed_or_event_window_opened",
      "exit_reasons": [
        "trim_after_range_expansion",
        "exit_if_breakout_fails_back_into_range"
      ]
    },
    "pin_reversion_exec": {
      "entry_style": "pin_fade_scaler",
      "scaling_step_factors": [
        0.5,
        0.5
      ],
      "default_inventory_action": "trim",
      "default_fresh_capital_action": "hold",
      "thesis_invalidation_state": "pin_released_or_flow_reaccelerated",
      "exit_reasons": [
        "exit_on_pin_release",
        "reduce_as_close_window_ends"
      ]
    },
    "negative_gamma_flush_exec": {
      "entry_style": "probe_then_hedge",
      "scaling_step_factors": [
        0.1,
        0.15
      ],
      "default_inventory_action": "hedge",
      "default_fresh_capital_action": "add",
      "thesis_invalidation_state": "flush_accelerates_or_bounce_fails",
      "exit_reasons": [
        "de-risk_into_bounce",
        "exit_if_hostile_flush_reaccelerates"
      ]
    },
    "front_expiry_pin_pressure_exec": {
      "entry_style": "front_pin_scaler",
      "scaling_step_factors": [
        0.35,
        0.65
      ],
      "default_inventory_action": "trim",
      "default_fresh_capital_action": "hold",
      "thesis_invalidation_state": "pin_build_failed_or_released",
      "exit_reasons": [
        "take_profit_into_pin",
        "exit_on_pin_release"
      ]
    },
    "term_structure_dislocation_exec": {
      "entry_style": "term_dislocation_probe",
      "scaling_step_factors": [
        0.25,
        0.35
      ],
      "default_inventory_action": "hold",
      "default_fresh_capital_action": "add",
      "thesis_invalidation_state": "term_structure_normalised",
      "exit_reasons": [
        "reduce_into_curve_normalisation",
        "exit_if_dislocation_fades"
      ]
    },
    "skew_pressure_reversal_exec": {
      "entry_style": "skew_reversal_scaler",
      "scaling_step_factors": [
        0.2,
        0.3
      ],
      "default_inventory_action": "hedge",
      "default_fresh_capital_action": "add",
      "thesis_invalidation_state": "skew_reversal_failed",
      "exit_reasons": [
        "de_risk_as_skew_normalises",
        "exit_if_reversal_fails"
      ]
    }
  }
}
